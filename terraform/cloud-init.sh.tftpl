#!/usr/bin/env bash
set -euxo pipefail

export DEBIAN_FRONTEND=noninteractive

apt-get update -y
apt-get install -y ca-certificates curl git jq lsof openssl sqlite3 tcpdump

modprobe tcp_bbr || true
echo tcp_bbr >/etc/modules-load.d/tcp_bbr.conf

cat >/etc/sysctl.d/99-3x-ui-proxy.conf <<SYSCTL
net.core.default_qdisc = fq
net.ipv4.tcp_congestion_control = bbr
net.core.rmem_max = ${udp_buffer_bytes}
net.core.wmem_max = ${udp_buffer_bytes}
net.ipv4.tcp_rmem = 4096 87380 ${udp_buffer_bytes}
net.ipv4.tcp_wmem = 4096 65536 ${udp_buffer_bytes}
net.ipv4.udp_rmem_min = 8192
net.ipv4.udp_wmem_min = 8192
net.ipv4.tcp_fastopen = 3
net.ipv4.tcp_mtu_probing = 1
net.ipv4.tcp_slow_start_after_idle = 0
net.core.somaxconn = 65535
net.core.netdev_max_backlog = 250000
SYSCTL

sysctl --system

mkdir -p /root/cert
if [ ! -s /root/cert/server.crt ] || [ ! -s /root/cert/server.key ]; then
  openssl req -x509 -nodes -newkey rsa:2048 -days 3650 \
    -keyout /root/cert/server.key \
    -out /root/cert/server.crt \
    -subj "/CN=${hysteria_cert_cn}" \
    -addext "subjectAltName=DNS:${hysteria_cert_cn}"
fi
chown root:root /root/cert /root/cert/server.crt /root/cert/server.key
chmod 755 /root/cert
chmod 644 /root/cert/server.crt
chmod 600 /root/cert/server.key

%{ if install_workspace_tools }
curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
apt-get install -y nodejs
npm install -g @anthropic-ai/claude-code || true
npm install -g @githubnext/github-copilot-cli || true
%{ endif }

%{ if install_3x_ui }
if [ ! -x /usr/local/x-ui/x-ui ]; then
  curl -fsSL https://raw.githubusercontent.com/MHSanaei/3x-ui/master/install.sh -o /root/install-3x-ui.sh
  chmod 700 /root/install-3x-ui.sh
  timeout 900 bash /root/install-3x-ui.sh
fi
%{ endif }

systemctl enable x-ui || true
systemctl restart x-ui || true
